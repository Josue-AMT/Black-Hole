```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Logs and temporary files
*.log
*.tmp
*.swp

# Environment files
.env
.env.local
*.env.*

# Editors/IDE
.vscode/
.idea/

# Coverage reports
.coverage
coverage/
htmlcov/

# Python cache
.mypy_cache/
.pytest_cache/

# Distribution and build artifacts
dist/
build/
*.egg-info/

# Virtual environments
.venv/
venv/
```